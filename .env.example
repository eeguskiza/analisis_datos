# ── Servidor web ─────────────────────────────────────────────────
OEE_HOST=0.0.0.0
OEE_PORT=8000
OEE_DEBUG=false

# ── SQL Server — ecs_mobility (app propia) ──────────────────────
OEE_DB_SERVER=192.168.0.4
OEE_DB_PORT=1433
OEE_DB_NAME=ecs_mobility
OEE_DB_USER=tu_usuario
OEE_DB_PASSWORD=tu_password

# ── SQL Server — IZARO (MES, solo lectura) ──────────────────────
# Usa las mismas credenciales de arriba, solo cambia la BD
OEE_IZARO_DB=dbizaro

# ── PostgreSQL (solo Docker) ────────────────────────────────────
OEE_PG_USER=oee
OEE_PG_PASSWORD=cambiar_en_produccion
OEE_PG_DB=oee_planta

# ── Sobreescribir URL completa (opcional, ignora campos de arriba)
# OEE_DATABASE_URL=mssql+pyodbc://user:pass@server:1433/db?driver=...

# Branding
NEXO_LOGO_PATH=/static/img/brand/nexo/logo.png
NEXO_ECS_LOGO_PATH=/static/img/brand/ecs/logo.png
NEXO_APP_NAME=Nexo
NEXO_COMPANY_NAME=ECS Mobility
