# Ejemplo de configuración de conexión a la BD.
# Este fichero es solo de referencia.
# La configuración real se guarda en data/db_config.json
# (creado automáticamente por la interfaz web).

DB_SERVER=192.168.x.x
DB_PORT=1433
DB_DATABASE=dbizaro
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_UF_CODE=          # código de empresa si hay varias (dejar vacío si no aplica)
DB_REF_CAMPO=dt030   # columna de fmesdtc con la referencia de pieza
