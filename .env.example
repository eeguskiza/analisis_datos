# Copia este fichero a .env y rellena los valores reales.
# NEXO_* son los nombres canonicos en Mark-III.
# OEE_* siguen funcionando como fallback (se eliminan en Mark-IV).

# ── Servidor web ─────────────────────────────────────────────────
NEXO_HOST=0.0.0.0
NEXO_PORT=8000
NEXO_DEBUG=false

# ── SQL Server — APP (ecs_mobility, BD propia de Nexo) ──────────
NEXO_APP_SERVER=192.168.0.4
NEXO_APP_PORT=1433
NEXO_APP_DB=ecs_mobility
NEXO_APP_USER=tu_usuario
NEXO_APP_PASSWORD=tu_password

# ── SQL Server — MES (dbizaro, IZARO, solo lectura) ─────────────
NEXO_MES_SERVER=192.168.0.4
NEXO_MES_PORT=1433
NEXO_MES_DB=dbizaro
NEXO_MES_USER=tu_usuario
NEXO_MES_PASSWORD=tu_password

# ── PostgreSQL (Docker, casa de nexo.*) ─────────────────────────
NEXO_PG_HOST=db
NEXO_PG_PORT=5432
NEXO_PG_USER=oee
NEXO_PG_PASSWORD=oee
NEXO_PG_DB=oee_planta

# ── Postgres — rol 'app' dedicado (Plan 02-04, gate IDENT-06) ──
# nexo_app tiene SELECT/INSERT/UPDATE/DELETE en el schema nexo EXCEPTO
# UPDATE/DELETE en nexo.audit_log (append-only). Generar password con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXO_PG_APP_USER=nexo_app
NEXO_PG_APP_PASSWORD=cambiar-por-password-aleatorio-32-chars

# ── Branding ────────────────────────────────────────────────────
NEXO_APP_NAME=Nexo
NEXO_COMPANY_NAME=ECS Mobility
NEXO_LOGO_PATH=/static/img/brand/nexo/logo.png
NEXO_ECS_LOGO_PATH=/static/img/brand/ecs/logo.png

# ── Auth (Phase 2) ──────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Sin valor por defecto — si falta, la app arranca con ValidationError.
NEXO_SECRET_KEY=
NEXO_SESSION_COOKIE_NAME=nexo_session
NEXO_SESSION_TTL_HOURS=12

# ── Legacy OEE_* (deprecadas, compat activa durante Mark-III) ───
# api/config.py acepta OEE_* como fallback si NEXO_* no esta definida.
# OEE_PG_USER=oee
# OEE_PG_PASSWORD=oee
# OEE_PG_DB=oee_planta

# ── Schema guard (Phase 3) ──────────────────────────────────────
# Si está en true y al arrancar faltan tablas en nexo.*, las crea
# automáticamente via NexoBase.metadata.create_all. SOLO dev /
# primer deploy. NUNCA en producción (usa `make nexo-init`).
# Tras cambiar .env: `docker compose up -d --force-recreate web`.
NEXO_AUTO_MIGRATE=false


# ── Phase 4: Consultas pesadas (Plan 04-02 / D-18) ──────────────
# Pipeline OEE: concurrency limit + soft timeout.
# Rango recomendado MAX_CONCURRENT: 1-5 (cada slot ~200MB pico de matplotlib).
# Rango recomendado TIMEOUT_SEC: 300-1800 (15 min = default; balance entre
# queries legítimas que tardan y detección de cuelgues).
#
# NOTE: el timeout es UX-soft — asyncio.wait_for cancela la corrutina pero
# NO mata el thread subyacente. matplotlib sigue corriendo hasta que termine
# su render (cleanup tmp_root corre en finally del thread). Ver
# docs/MARK_III_PLAN.md Sprint 3 y 04-RESEARCH.md §Pitfall 1.
NEXO_PIPELINE_MAX_CONCURRENT=3
NEXO_PIPELINE_TIMEOUT_SEC=900
