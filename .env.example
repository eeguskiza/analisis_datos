# Configuracion de la app OEE (variables opcionales)
# Copiar a .env y editar

# Base de datos (Docker usa PostgreSQL, local usa SQLite por defecto)
# OEE_DATABASE_URL=postgresql://oee:oee@localhost:5432/oee_planta
# OEE_DATABASE_URL=sqlite:///data/oee.db

# Rutas (por defecto: relativas al proyecto)
# OEE_DATA_DIR=/app/data
# OEE_INFORMES_DIR=/app/informes

# Servidor
# OEE_HOST=0.0.0.0
# OEE_PORT=8000
# OEE_DEBUG=false

# La conexion a BD MES se configura en data/db_config.json
